.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml
*.lock

# Flutter generated files
*.g.dart
*.freezed.dart

# Android
android/app/debug/
android/app/profile/
android/app/release/
android/.gradle/
android/gradle/
android/local.properties
android/captures/
android/gradlew
android/gradlew.bat
android/key.properties

