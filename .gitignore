.vscode/
.idea/
*.swp
*.swo

# Environment
.env

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Images (student work) - leading slash restricts to root only
/images/

# Data files (PDFs are local only - possible copyright/size issues)
data/papers/sources/
data/students/work/

# OS
.DS_Store

# Quality reports
.quality/

# FVM (Flutter Version Management)
# Keep: .fvm/fvm_config.json (committed to lock Flutter version)

