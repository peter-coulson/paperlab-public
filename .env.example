# PaperLab Application Configuration
# Copy this file to .env and customize as needed
# All variables are prefixed with PAPERLAB_

# ============================================================================
# Database Configuration
# ============================================================================

# Database filename (will be created in project root)
PAPERLAB_DATABASE_NAME=marking.db

# Optional: Full path to database file (overrides DATABASE_NAME if set)
# PAPERLAB_DATABASE_PATH=/custom/path/marking.db

# ============================================================================
# Sample Data Configuration
# ============================================================================

# Whether to load sample data during db init
PAPERLAB_SAMPLE_DATA_ENABLED=true

# Path to sample data configuration file (relative to project root)
PAPERLAB_SAMPLE_DATA_CONFIG=data/config/sample_data.json

# ============================================================================
# LLM API Keys (REQUIRED for marking)
# ============================================================================
# SECURITY: Never commit .env file with real API keys!
# .env is in .gitignore - keep it that way

# MVP Testing: Claude Sonnet 4.5 (quality baseline) + GPT-4o (cost comparison)
# Other providers deferred until quality validated

# Anthropic API key for Claude models
# Get yours at: https://console.anthropic.com/
# Format: sk-ant-...
PAPERLAB_ANTHROPIC_API_KEY=

# OpenAI API key for GPT models
# Get yours at: https://platform.openai.com/api-keys
# Format: sk-...
PAPERLAB_OPENAI_API_KEY=

# Google Gemini API key (for Gemini models via OpenAI compatibility)
# Get yours at: https://aistudio.google.com/apikey
# Format: AI...
PAPERLAB_GOOGLE_API_KEY=

# ============================================================================
# LLM Configuration
# ============================================================================

# Default model to use (REQUIRED - must exist in llm_models table)
# Options: gpt-4o (OpenAI), claude-sonnet-4-5-20250929 (Anthropic)
PAPERLAB_DEFAULT_MODEL=gpt-4o

# Maximum tokens for prompts (safety check)
PAPERLAB_MAX_PROMPT_TOKENS=100000

# Request timeout in seconds
PAPERLAB_LLM_TIMEOUT=120

# Maximum retry attempts on transient failures
PAPERLAB_LLM_MAX_RETRIES=3

# ============================================================================
# Directory Paths (relative to project root)
# ============================================================================

PAPERLAB_DATA_DIR=data
PAPERLAB_PROCESSED_DIR=data/processed
PAPERLAB_MIGRATIONS_DIR=data/migrations

# ============================================================================
# Cloudflare R2 Storage Configuration
# ============================================================================
# SECURITY: Never commit .env file with real credentials!

# Cloudflare Account ID
# Find at: Cloudflare Dashboard > R2 > Overview
PAPERLAB_R2_ACCOUNT_ID=

# R2 S3 API Credentials
# Generate at: Cloudflare Dashboard > R2 > Manage R2 API Tokens
PAPERLAB_R2_ACCESS_KEY_ID=
PAPERLAB_R2_SECRET_ACCESS_KEY=

# R2 Bucket Name (Permanent Storage)
# Create at: Cloudflare Dashboard > R2 > Create Bucket
PAPERLAB_R2_BUCKET_NAME=

# R2 Staging Bucket Name (Temporary Uploads)
# Create separate bucket with 24h lifecycle rule
# Used for atomic commit pattern: staging → permanent
PAPERLAB_R2_STAGING_BUCKET=

# R2 Public URL (r2.dev subdomain for M7 beta, custom domain for M9 production)
# Get at: Cloudflare Dashboard > R2 > Bucket > Settings > Public Development URL
# Format: https://pub-{hash}.r2.dev
# TODO (M9): Replace with custom domain (e.g., https://images.paperlab.app)
PAPERLAB_R2_PUBLIC_URL=

# ============================================================================
# Environment
# ============================================================================

# Environment: development, staging, or production
PAPERLAB_ENVIRONMENT=development
